-- ===== ATM HELPERS =====
local function getATMFolder()
    local funcs = workspace:FindFirstChild("Functions")
    if not funcs then return nil end
    local shopRob = funcs:FindFirstChild("Shop_Rob")
    if not shopRob then return nil end
    return shopRob:FindFirstChild("InkasseBank")
end

function countATMs()
    local atmFolder = getATMFolder()
    if not atmFolder then return 0 end
    local count = 0
    for _, model in ipairs(atmFolder:GetChildren()) do
        if model:IsA("Model") and model.Name == "ATM" then
            count = count + 1
        end
    end
    debug("ATM Count: " .. tostring(count))
    return count
end

function checkATMsBeforeExit()
    local atmFolder = getATMFolder()
    if not atmFolder then return false end
    local brokenCount = 0
    local totalATM = 0
    for _, model in ipairs(atmFolder:GetChildren()) do
        if model:IsA("Model") and model.Name == "ATM" then
            totalATM = totalATM + 1
            if model:GetAttribute("Destroyed") == true then
                brokenCount = brokenCount + 1
                debug("ATM = Destroyed")
            else
                debug("ATM = Intakt")
            end
        end
    end
    if totalATM > 0 and brokenCount == totalATM then
        debug("Alle ATMs zerstört, Bank wird übersprungen.")
        return true
    end
    return false
end

-- ===== ATM DESTROY =====
function destroyATMs()
    local atmFolder = getATMFolder()
    if not atmFolder then debug("ATM Folder nicht gefunden!") return end

    local damageRemote = nil
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            local remote = item:FindFirstChild("OnDamageEvent")
            if remote then
                damageRemote = remote
                debug("OnDamageEvent gefunden in Backpack: " .. item.Name)
                break
            end
        end
    end
    if not damageRemote and player.Character then
        for _, item in ipairs(player.Character:GetChildren()) do
            local remote = item:FindFirstChild("OnDamageEvent")
            if remote then
                damageRemote = remote
                debug("OnDamageEvent gefunden in Character: " .. item.Name)
                break
            end
        end
    end
    if not damageRemote then
        debug("OnDamageEvent Remote nicht gefunden!")
        return
    end

    local atms = {}
    for _, model in ipairs(atmFolder:GetChildren()) do
        if model:IsA("Model") and model.Name == "ATM" then
            table.insert(atms, model)
        end
    end
    debug("Zerstöre " .. tostring(#atms) .. " ATMs...")

    for i, atm in ipairs(atms) do
        local hitPart = atm:FindFirstChild("Detail2")
        if not hitPart then
            for _, p in ipairs(atm:GetDescendants()) do
                if p:IsA("BasePart") then hitPart = p break end
            end
        end
        if not hitPart then debug("Kein HitPart bei ATM " .. i) continue end

        -- Feuern bis Destroyed=true oder timeout
        local timeout = os.clock() + 10
        while not atm:GetAttribute("Destroyed") and os.clock() < timeout do
            for _ = 1, 3 do
                pcall(function()
                    damageRemote:FireServer(unpack({
                        {
                            {
                                HitType = 3,
                                Model = atm,
                                Hit = hitPart
                            }
                        },
                        3
                    }))
                end)
                task.wait(0.1)
            end
        end

        if atm:GetAttribute("Destroyed") then
            debug("ATM " .. i .. " erfolgreich zerstört")
        else
            debug("ATM " .. i .. " timeout - weiter")
        end
    end
end

function collectCash()
