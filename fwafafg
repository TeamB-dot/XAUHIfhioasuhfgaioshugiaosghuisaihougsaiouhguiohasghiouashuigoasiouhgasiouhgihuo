    local collected = 0

    for runde = 1, 3 do
        for _, b in ipairs(ig:GetChildren()) do
            if b:IsA("BasePart") then
                local p = b:FindFirstChildOfClass("ProximityPrompt")
                if p then
                    -- Spieler zum Geld teleportieren
                    root.CFrame = CFrame.new(b.Position + Vector3.new(0, 3, 0))

                    p.HoldDuration = 0
                    p.MaxActivationDistance = 999
                    p.RequiresLineOfSight = false

                    pcall(function() fireproximityprompt(p) end)
                    task.wait(0.05)
                    pcall(function() fireproximityprompt(p) end)
                    task.wait(0.05)
                    pcall(function() fireproximityprompt(p) end)

                    collected = collected + 1
                end
            end
        end
        task.wait(0.5)
    end

    debug("Cash eingesammelt: " .. tostring(collected))
end

