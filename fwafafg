function robShop(shopInfo)
    debug("Starte Raub: " .. tostring(shopInfo.n))

    -- Spieler teleportieren
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then debug("Kein HRP!") return false end
    root.CFrame = shopInfo.p
    task.wait(1)

    -- Dummy suchen
    local dummy
    local funcs = workspace:FindFirstChild("Functions")
    if funcs then
        local shopRob = funcs:FindFirstChild("Shop_Rob")
        if shopRob then
            local model = shopRob:FindFirstChild(shopInfo.n)
            if model then dummy = model:FindFirstChild("Dummy") end
        end
    end

    if not dummy then warn("Dummy nicht gefunden: " .. shopInfo.n) return false end
    if not dummy:GetAttribute("CanRobNPC") then
        debug(shopInfo.n .. " CanRobNPC=false, überspringe.")
        return false
    end

    local remote = dummy:FindFirstChild("OnRob")
    if not remote then warn("OnRob fehlt bei: " .. shopInfo.n) return false end

    debug("Spamme OnRob bis CanRobNPC false...")
    local robTimeout = os.clock() + 15
    while dummy:GetAttribute("CanRobNPC") and os.clock() < robTimeout do
        pcall(function() remote:FireServer() end)
        task.wait(1)
    end

    debug(shopInfo.n .. " fertig, sammle Cash...")
    task.wait(0.5)
    collectCash()
    return true
end

