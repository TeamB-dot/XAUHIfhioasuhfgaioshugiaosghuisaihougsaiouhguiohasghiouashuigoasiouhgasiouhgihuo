-- Anti Cop (Ragdoll Detector)
local function setupAntiCop()
    local function watchCharacter(char)
        if not char then return end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end

        -- Attribute watcher
        humanoid.AttributeChanged:Connect(function(attr)
            if attr == "Ragdoll" and humanoid:GetAttribute("Ragdoll") == true then
                warn("🚔 RAGDOLL erkannt - Stoppe Farm!")
                stopEverything()
            end
        end)

        -- auch workspace.Characters checken
        local charFolder = workspace:FindFirstChild("Characters")
        if charFolder then
            local playerChar = charFolder:FindFirstChild(player.Name)
            if playerChar then
                local hum = playerChar:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.AttributeChanged:Connect(function(attr)
                        if attr == "Ragdoll" and hum:GetAttribute("Ragdoll") == true then
                            warn("🚔 RAGDOLL (workspace.Characters) erkannt - Stoppe Farm!")
                            stopEverything()
                        end
                    end)
                end
            end
        end
    end

    watchCharacter(player.Character)
    player.CharacterAdded:Connect(watchCharacter)
end

-- Anti Die (Health Monitor)
local function setupAntiDie()
    local function watchHealth(char)
        if not char then return end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end

        RunService.Heartbeat:Connect(function()
            if _G.StopFarm then return end
            if humanoid.Health > 0 and humanoid.Health <= 20 then
                warn("❤️ Health kritisch (" .. math.floor(humanoid.Health) .. ") - Stoppe Farm!")
                stopEverything()
            end
        end)
    end

    watchHealth(player.Character)
    player.CharacterAdded:Connect(watchHealth)
end

setupAntiCop()
